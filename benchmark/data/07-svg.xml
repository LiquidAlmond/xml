<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 800 600" width="800" height="600">
    <defs>
        <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
        </linearGradient>
        <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="3" dy="3" stdDeviation="3" flood-opacity="0.3"/>
        </filter>
        <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
            <path d="M 20 0 L 0 0 0 20" fill="none" stroke="white" stroke-width="0.5" opacity="0.2"/>
        </pattern>
        <symbol id="icon-user" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="4" fill="white"/>
            <path d="M12 14c-4 0-8 2-8 4v2h16v-2c0-2-4-4-8-4z" fill="white"/>
        </symbol>
    </defs>
    
    <rect width="800" height="600" fill="url(#bgGradient)"/>
    <rect width="800" height="600" fill="url(#grid)"/>
    
    <g id="header" transform="translate(0, 20)">
        <text x="400" y="50" text-anchor="middle" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="white">SVG Graphics Demo</text>
        <line x1="100" y1="80" x2="700" y2="80" stroke="white" stroke-width="2" opacity="0.5"/>
    </g>
    
    <g id="charts" transform="translate(50, 120)">
        <g id="bar-chart">
            <text x="0" y="0" font-family="Arial" font-size="18" fill="white">Sales by Quarter</text>
            <rect x="20" y="30" width="40" height="150" fill="#ff6b6b" rx="5">
                <animate attributeName="height" from="0" to="150" dur="1s" fill="freeze"/>
                <animate attributeName="y" from="180" to="30" dur="1s" fill="freeze"/>
            </rect>
            <rect x="80" y="60" width="40" height="120" fill="#4ecdc4" rx="5">
                <animate attributeName="height" from="0" to="120" dur="1s" begin="0.2s" fill="freeze"/>
                <animate attributeName="y" from="180" to="60" dur="1s" begin="0.2s" fill="freeze"/>
            </rect>
            <rect x="140" y="20" width="40" height="160" fill="#45b7d1" rx="5">
                <animate attributeName="height" from="0" to="160" dur="1s" begin="0.4s" fill="freeze"/>
                <animate attributeName="y" from="180" to="20" dur="1s" begin="0.4s" fill="freeze"/>
            </rect>
            <rect x="200" y="50" width="40" height="130" fill="#96ceb4" rx="5">
                <animate attributeName="height" from="0" to="130" dur="1s" begin="0.6s" fill="freeze"/>
                <animate attributeName="y" from="180" to="50" dur="1s" begin="0.6s" fill="freeze"/>
            </rect>
            <text x="40" y="200" text-anchor="middle" font-family="Arial" font-size="12" fill="white">Q1</text>
            <text x="100" y="200" text-anchor="middle" font-family="Arial" font-size="12" fill="white">Q2</text>
            <text x="160" y="200" text-anchor="middle" font-family="Arial" font-size="12" fill="white">Q3</text>
            <text x="220" y="200" text-anchor="middle" font-family="Arial" font-size="12" fill="white">Q4</text>
        </g>
        
        <g id="pie-chart" transform="translate(350, 0)">
            <text x="75" y="0" font-family="Arial" font-size="18" fill="white">Market Share</text>
            <circle cx="75" cy="100" r="70" fill="#2c3e50"/>
            <path d="M75 30 A70 70 0 0 1 135 65" fill="#ff6b6b">
                <animate attributeName="d" from="M75 100 L75 100 A70 70 0 0 1 75 30" to="M75 100 L75 30 A70 70 0 0 1 135 65" dur="1s" fill="freeze"/>
            </path>
            <path d="M135 65 A70 70 0 0 1 75 170" fill="#4ecdc4">
                <animate attributeName="d" from="M75 100 L75 100 A70 70 0 0 1 75 170" dur="1s" begin="0.3s" fill="freeze"/>
            </path>
            <path d="M75 170 A70 70 0 0 1 15 65" fill="#45b7d1">
                <animate attributeName="d" from="M75 100 L75 100 A70 70 0 0 1 15 65" dur="1s" begin="0.6s" fill="freeze"/>
            </path>
            <path d="M15 65 A70 70 0 0 1 75 30" fill="#96ceb4">
                <animate attributeName="d" from="M75 100 L75 100 A70 70 0 0 1 75 30" dur="1s" begin="0.9s" fill="freeze"/>
            </path>
            <text x="75" y="105" text-anchor="middle" font-family="Arial" font-size="14" fill="white">100%</text>
            <g transform="translate(160, 30)">
                <rect x="0" y="0" width="15" height="15" fill="#ff6b6b"/>
                <text x="20" y="12" font-family="Arial" font-size="12" fill="white">Product A (35%)</text>
                <rect x="0" y="25" width="15" height="15" fill="#4ecdc4"/>
                <text x="20" y="37" font-family="Arial" font-size="12" fill="white">Product B (25%)</text>
                <rect x="0" y="50" width="15" height="15" fill="#45b7d1"/>
                <text x="20" y="62" font-family="Arial" font-size="12" fill="white">Product C (20%)</text>
                <rect x="0" y="75" width="15" height="15" fill="#96ceb4"/>
                <text x="20" y="87" font-family="Arial" font-size="12" fill="white">Product D (20%)</text>
            </g>
        </g>
    </g>
    
    <g id="user-list" transform="translate(50, 380)">
        <text x="0" y="0" font-family="Arial" font-size="18" fill="white">Recent Users</text>
        <g transform="translate(0, 20)">
            <use xlink:href="#icon-user" x="0" y="0" width="24" height="24"/>
            <text x="35" y="18" font-family="Arial" font-size="14" fill="white">John Doe</text>
            <text x="200" y="18" font-family="Arial" font-size="12" fill="white" opacity="0.7">Active now</text>
        </g>
        <g transform="translate(0, 55)">
            <use xlink:href="#icon-user" x="0" y="0" width="24" height="24"/>
            <text x="35" y="18" font-family="Arial" font-size="14" fill="white">Jane Smith</text>
            <text x="200" y="18" font-family="Arial" font-size="12" fill="white" opacity="0.7">Last seen 5m ago</text>
        </g>
        <g transform="translate(0, 90)">
            <use xlink:href="#icon-user" x="0" y="0" width="24" height="24"/>
            <text x="35" y="18" font-family="Arial" font-size="14" fill="white">Bob Wilson</text>
            <text x="200" y="18" font-family="Arial" font-size="12" fill="white" opacity="0.7">Active now</text>
        </g>
    </g>
    
    <g id="footer" transform="translate(0, 550)">
        <line x1="100" y1="0" x2="700" y2="0" stroke="white" stroke-width="2" opacity="0.5"/>
        <text x="400" y="25" text-anchor="middle" font-family="Arial" font-size="12" fill="white" opacity="0.7">Generated with SVG • Interactive Vector Graphics</text>
    </g>
</svg>
