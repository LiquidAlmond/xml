{
  "name": "@liquid/xml",
  "version": "1.0.0",
  "description": "XML parser and stringifier with JSON-compatible API",
  "homepage": "https://github.com/LiquidAlmond/xml#readme",
  "bugs": {
    "url": "https://github.com/LiquidAlmond/xml/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiquidAlmond/xml.git"
  },
  "license": "MIT",
  "author": "LiquidAlmond",
  "type": "module",
  "main": "dist/xml.cjs.js",
  "module": "dist/xml.esm.js",
  "types": "dist/index.d.ts",
  "browser": "dist/xml.js",
  "exports": {
    ".": {
      "browser": "./dist/xml.js",
      "import": "./dist/xml.esm.js",
      "require": "./dist/xml.cjs.js"
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "test": "vitest",
    "bench": "vitest bench",
    "compare-bench": "node benchmark/fetch-benchmarks.mjs && vitest bench benchmark/compare",
    "format": "biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.5.0",
    "@xmldom/xmldom": "^0.8.11",
    "esbuild": "^0.27.3",
    "fast-xml-parser": "^5.5.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
